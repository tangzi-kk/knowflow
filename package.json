{
  "name": "sync-plugin",
  "version": "3.0.1",
  "private": true,
  "description": "飞书 ↔ Obsidian 知识库同步闭环（浏览器扩展 + OB 插件，通过 localhost HTTP 通信）",
  "license": "MIT",
  "workspaces": [
    "packages/*",
    "extension"
  ],
  "scripts": {
    "build:shared": "npm run build -w @sync/shared",
    "build:ob": "npm run build -w @sync/ob-plugin",
    "build:ext": "npm run build -w @sync/extension",
    "build": "npm run build:shared && npm run build:ob && npm run build:ext",
    "test:protocol": "npm run build:shared && node scripts/protocol-uri-test.mjs",
    "dev": "npm run dev --workspaces"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.250",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.19.43",
    "esbuild": "^0.20.2",
    "obsidian": "^1.13.1",
    "typescript": "^5.9.3"
  }
}
