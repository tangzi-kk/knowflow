{
   "action": {
      "default_icon": {
         "128": "icons/icon128.png",
         "16": "icons/icon16.png",
         "48": "icons/icon48.png"
      },
      "default_title": "Feishu Doc Exporter"
   },
   "background": {
      "service_worker": "background.js"
   },
   "content_scripts": [ {
      "js": [ "content.js" ],
      "matches": [ "*://*.feishu.cn/*" ],
      "run_at": "document_idle"
   } ],
   "description": "一键将飞书文档转换为 Markdown 格式，悬浮面板操作更便捷。",
   "icons": {
      "128": "icons/icon128.png",
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
   },
   "key": "",
   "manifest_version": 3,
   "name": "Feishu Doc Exporter",
   "permissions": [ "activeTab", "scripting", "clipboardWrite" ],
   "update_url": "https://clients2.google.com/service/update2/crx",
   "version": "0.3.0"
}
